---
title: GAS Companion Documentation
layout: layouts/main
---


<div class="Layout">
    <div class="Layout-main">
        <main class="markdown-content p-6">

            <nav aria-label="Breadcrumb" class="mb-3">
            <ol>
                {%- for entry in breadcrumb %}
                    <li class="breadcrumb-item{% if entry.url == page.url %} breadcrumb-item-selected{% endif %}">
                        <a href="{{ entry.url | url }}">{{ entry.title }}</a>
                    </li>
                {%- endfor %}
            </ol>
            </nav>

            <article  class="markdown-body">
                {{ content | safe }}

                <hr />
                <p>Generated on {{ page.date.toUTCString() }}</p>
            </article>
        </main>
    </div>

    <div class="Layout-sidebar color-bg-subtle ">{% include 'components/sidebar2.njk' %}</div>
    {# <div class="Layout-sidebar bg-primary position-sticky top-0 overflow-y-auto flex-shrink-0 pb-5 border-right">{% include 'components/sidebar2.njk' %}</div> #}
</div>

{% set breadcrumb = collections.all | eleventyNavigationBreadcrumb(eleventyNavigation.key, { includeSelf: true }) %}

